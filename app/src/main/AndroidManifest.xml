<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Feed fetch (spec §7.7) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Deadline reminders (spec §7.6). Runtime-requested on Android 13+ in MainActivity;
         the app must still work fully if this is denied - see ReminderScheduler. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Lets a scheduled WorkManager reminder still fire promptly (spec §7.6 honesty
         note: even with this, delivery isn't guaranteed - OEM battery optimisation
         can still delay it, which is exactly why the UI never promises exact timing). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".KaziSasaApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@android:style/Theme.Material.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
